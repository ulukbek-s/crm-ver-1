{
  "name": "platform",
  "version": "1.0.0",
  "private": true,
  "description": "Corporate HR, Migration and Education Operating System",
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspace=api-gateway",
    "dev:gateway": "npm run dev --workspace=api-gateway",
    "dev:frontend": "npm run dev --workspace=frontend",
    "docker:up": "docker compose -f infrastructure/docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f infrastructure/docker/docker-compose.yml down",
    "db:generate": "npm run generate --workspace=@platform/database",
    "db:push": "dotenv -e .env -- npm run db:push --workspace=@platform/database",
    "db:seed": "dotenv -e .env -- npm run db:seed --workspace=@platform/database",
    "db:migrate": "dotenv -e .env -- npm run migrate --workspace=@platform/database",
    "test": "npm run test --workspaces --if-present"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.2"
  }
}
